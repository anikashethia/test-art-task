# Copy to backend/.env and fill in. Never commit .env.

# DB file (relative to backend/)
DATABASE_URL=sqlite:///./social_influence.db

# CORS — set to deployed frontend URL in production
# Local dev:
FRONTEND_ORIGIN=http://localhost:5174
# Deployed:
# FRONTEND_ORIGIN=https://your-influence-task.com

# Prolific completion URL — from your Prolific study dashboard
PROLIFIC_COMPLETION_URL=https://app.prolific.com/submissions/complete?cc=XXXXXXXX
